# ──── Supabase (for blog + contact form) ────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only

# ──── GTCS Tenant (used to namespace blog posts in Supabase) ─────────────────
NEXT_PUBLIC_TENANT_ID=gtcs

# ──── Site Info ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=Gentech Consultancy Services
NEXT_PUBLIC_SITE_URL=https://gentechcs.in
NEXT_PUBLIC_PHONE=+919876543210          # WhatsApp-linked number
NEXT_PUBLIC_EMAIL=hello@gentechcs.in
NEXT_PUBLIC_WHATSAPP=919876543210        # no +, no spaces

# ──── Resend (email notifications for contact form) ──────────────────────────
# Free tier: 100 emails/day — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
ADMIN_EMAIL=admin@gentechcs.in

# ──── SaaS Backend URL (Render deployment) ───────────────────────────────────
NEXT_PUBLIC_SAAS_API_URL=https://hospiflow-saas-backend.onrender.com

# ──── App Download URLs ───────────────────────────────────────────────────────
# Where the actual .exe and .apk files are hosted.
# Recommended: GitHub Releases (free, fast CDN, 2GB per file limit)
# After uploading to GitHub Releases, set these to the release asset URLs.
# The /download page buttons → /downloads/HospiFlow-Setup.exe → redirect here.
DOWNLOAD_EXE_URL=https://github.com/gentech-consultancy/hospiflow/releases/download/v1.0.0/HospiFlow-Setup.exe
DOWNLOAD_APK_URL=https://github.com/gentech-consultancy/hospiflow/releases/download/v1.0.0/hospiflow-pos.apk
